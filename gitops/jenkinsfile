@Library('Shared') _
pipeline {
    agent { label 'Node' }
    
    environment {
        // Centralized variables so you only change them once
        APP_IMAGE = "samarthlambture/angularspree"
        GIT_REPO_URL = "https://github.com/SamarthLambture/ecommerce-app-2-devops.git"
        NOTIFY_EMAIL = "lambture5522@gmail.com"
    }
    
    parameters {
        // Matches exactly what the CI pipeline is passing
        string(name: 'IMAGE_TAG', defaultValue: '', description: 'Docker tag of the image built by the CI job')
    }

    stages {
        stage("Workspace cleanup"){
            steps{
                script{
                    cleanWs()
                }
            }
        }
        
        stage('Git: Code Checkout') {
            steps {
                script{
                    code_checkout("${env.GIT_REPO_URL}", "main")
                }
            }
        }
        
        stage('Verify: Docker Image Tag') {
            steps {
                script{
                    echo "Deploying IMAGE_TAG: ${params.IMAGE_TAG}"
                }
            }
        }
        
        stage("Update: Kubernetes manifests"){
            steps{
                script{
                    // This assumes your deployment file is in a folder named 'kubernetes' 
                    // and is named 'deployment.yaml'. Update the path if necessary!
                    dir('k8s-manifests'){
                        sh """
                            sed -i 's|image: ${env.APP_IMAGE}:.*|image: ${env.APP_IMAGE}:${params.IMAGE_TAG}|g' deployment.yaml
                        """
                    }
                }
            }
        }
        
        stage("Git: Commit and Push"){
            steps{
                script{
                    // Ensure you have created this 'Github-cred' credential in Jenkins (Username + Personal Access Token)
                    withCredentials([gitUsernamePassword(credentialsId: 'Github-cred', gitToolName: 'Default')]) {
                        sh """
                        echo "Checking repository status: "
                        git status
                    
                        echo "Adding changes to git: "
                        git add .
                        
                        echo "Commiting changes: "
                        git commit -m "Automated CD Update: Deploying ${params.IMAGE_TAG}"
                        
                        echo "Pushing changes to github: "
                        git push ${env.GIT_REPO_URL} main
                        """
                    }
                }
            }
        }
    }
  post {
        success {
            script {
                emailext attachLog: false, // Turned off to save email size, turn on if needed
                from: "${env.NOTIFY_EMAIL}",
                subject: "SUCCESS: ${env.JOB_NAME} Deployment - Tag: ${params.IMAGE_TAG}",
                body: """
                    <html>
                    <body>
                        <div style="background-color: #90EE90; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">ArgoCD will now sync the new image!</p>
                            <p>Project: ${env.JOB_NAME}</p>
                            <p>Tag Deployed: ${params.IMAGE_TAG}</p>
                            <p>URL: ${env.BUILD_URL}</p>
                        </div>
                    </body>
                    </html>
            """,
            to: "${env.NOTIFY_EMAIL}",
            mimeType: 'text/html'
            }
        }
      failure {
            script {
                emailext attachLog: true,
                from: "${env.NOTIFY_EMAIL}",
                subject: "FAILED: ${env.JOB_NAME} Deployment",
                body: """
                    <html>
                    <body>
                        <div style="background-color: #FFA07A; padding: 10px; margin-bottom: 10px;">
                            <p style="color: black; font-weight: bold;">Deployment Pipeline Failed.</p>
                            <p>Project: ${env.JOB_NAME}</p>
                            <p>URL: ${env.BUILD_URL}</p>
                        </div>
                    </body>
                    </html>
            """,
            to: "${env.NOTIFY_EMAIL}",
            mimeType: 'text/html'
            }
        }
    }
}